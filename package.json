{
    "name": "@mat3ra/parsers",
    "version": "0.0.0",
    "description": "Parsers Py/JS",
    "author": "Exabyte Inc.",
    "license": "ISC",
    "main": "dist/index.js",
    "files": [
        "/dist",
        "/src/js",
        "tsconfig.json"
    ],
    "dependencies": {
        "@babel/cli": "^7.29.7",
        "@babel/core": "^7.29.7",
        "@babel/eslint-parser": "^7.29.7",
        "@babel/plugin-proposal-class-properties": "^7.18.6",
        "@babel/preset-env": "^7.29.7",
        "@babel/preset-react": "^7.29.7",
        "@babel/preset-typescript": "^7.29.7",
        "@babel/register": "^7.29.7",
        "@babel/runtime-corejs3": "^7.29.7",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    },
    "devDependencies": {
        "@exabyte-io/eslint-config": "^2025.5.13-0",
        "@mat3ra/tsconfig": "^2024.6.3-0",
        "@types/chai": "^4.3.20",
        "@types/mocha": "^10.0.10",
        "@types/node": "^20.19.41",
        "@typescript-eslint/eslint-plugin": "^5.62.0",
        "@typescript-eslint/parser": "^5.62.0",
        "babel-eslint": "^10.1.0",
        "chai": "^4.5.0",
        "eslint": "^7.32.0",
        "eslint-config-airbnb": "^19.0.4",
        "eslint-config-prettier": "^8.10.2",
        "eslint-import-resolver-exports": "^1.0.0-beta.5",
        "eslint-import-resolver-node": "^0.3.10",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsdoc": "^37.9.7",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-mui-path-imports": "^0.0.15",
        "eslint-plugin-prettier": "^4.2.5",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-simple-import-sort": "^7.0.0",
        "husky": "^7.0.4",
        "lint-staged": "^12.5.0",
        "mocha": "^10.8.2",
        "nyc": "^15.1.0",
        "prettier": "^2.8.8"
    },
    "scripts": {
        "lint": "eslint --cache src/js tests/js && prettier --write src/js tests/js",
        "lint:fix": "eslint --fix --cache src/js tests/js && prettier --write src/js tests/js",
        "lint:staged": "lint-staged",
        "postinstall": "npm run transpile",
        "prepare": "husky install || exit 0",
        "prettier": "prettier --check src/js tests/js",
        "test": "nyc --reporter=text mocha --recursive --bail tests/js",
        "transpile": "tsc"
    },
    "engines": {
        "node": ">=14.0.0"
    },
    "lint-staged": {
        "*.{js,ts,tsx}": "eslint --cache --fix",
        "*.{js,ts,tsx,css}": "prettier --write"
    }
}
